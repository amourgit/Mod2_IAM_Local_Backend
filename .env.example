# =============================================
# Variables d'environnement - Template
# Copiez ce fichier en .env et adaptez les valeurs
# =============================================

KC_DB=postgres
KC_DB_URL=jdbc:postgresql://localhost:5432/keycloak_iam_local
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak_secret_uob_2025
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# ── Redis ───────────────────────────────────────────────────
REDIS_PASSWORD=votre_mot_de_passe_redis

# ── Configuration Production ───────────────────────────────
KEYCLOAK_HOSTNAME=keycloak.entreprise.fr

# ── SSL/TLS ─────────────────────────────────────────────────
# Placez vos certificats dans ./ssl et ./ssl-private
# SSL_CERTIFICATE_FILE=/etc/ssl/certs/keycloak.crt
# SSL_CERTIFICATE_KEY_FILE=/etc/ssl/private/keycloak.key
