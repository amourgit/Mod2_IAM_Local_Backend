# =============================================
# Configuration Keycloak - Production
# =============================================

# Port HTTP
KC_HTTP_PORT=8080

# Base de données PostgreSQL
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://db-postgres:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=${KEYCLOAK_DB_PASSWORD}
KC_DB_MIGRATION=auto

# Hostname (production)
KC_HOSTNAME_STRICT=true
KC_HOSTNAME=keycloak.entreprise.fr
KC_HTTPS_ENABLED=true
KC_HTTPS_CERTIFICATE_FILE=/etc/ssl/certs/keycloak.crt
KC_HTTPS_CERTIFICATE_KEY_FILE=/etc/ssl/private/keycloak.key

# Features activées
KC_FEATURES=account-api,admin-fine-grained-authz,token-exchange

# Logs
KC_LOG_LEVEL=WARN
KC_LOG_CONSOLE_OUTPUT=json
KC_LOG_FILE=/var/log/keycloak/keycloak.log

# =============================================
# Configuration Module IAM Compte - Production
# =============================================

# Connexion Keycloak
KEYCLOAK_AUTH_SERVER_URL=https://keycloak.entreprise.fr
KEYCLOAK_REALM=production

# Base de données IAM (PostgreSQL)
SPRING_DATASOURCE_URL=jdbc:postgresql://db-iam:5432/iam_production
SPRING_DATASOURCE_USERNAME=iam_app
SPRING_DATASOURCE_PASSWORD=${IAM_DB_PASSWORD}
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=kafka-cluster:9092
SPRING_KAFKA_CONSUMER_GROUP=iam-compte-prod-consumer
SPRING_KAFKA_TOPIC=compte-provisioning
SPRING_KAFKA_SECURITY_PROTOCOL=SSL

# Profiles
SPRING_PROFILES_ACTIVE=prod
QUARKUS_PROFILE=prod

# =============================================
# Configuration sécurité production
# =============================================

# CORS
KC_HTTP_CORS=true
KC_HTTP_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
KC_HTTP_CORS_ALLOWED_ORIGINS=https://app.entreprise.fr,https://admin.entreprise.fr

# Cache
KC_CACHE=ispn
KC_CACHE_STACK=default

# Health checks
KC_HEALTH_ENABLED=true

# Metrics
KC_METRICS_ENABLED=true
KC_METRICS_HTTP_ROOT=/metrics
