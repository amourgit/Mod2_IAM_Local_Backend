# =============================================
# Configuration Keycloak - Développement
# =============================================

# Port HTTP
KC_HTTP_PORT=8080

# Copiez-collez directement dans votre terminal
export KC_HTTP_PORT=8080
export KC_DB=postgres
export KC_DB_URL=jdbc:postgresql://localhost:5433/keycloak
export KC_DB_USERNAME=keycloak
export KC_DB_PASSWORD=password
export KC_HOSTNAME_STRICT=false
export KC_FEATURES=preview


# Logs
KC_LOG_LEVEL=INFO
KC_LOG_CONSOLE_OUTPUT=json

# =============================================
# Configuration Module IAM Compte
# =============================================

# Connexion Keycloak
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8080
KEYCLOAK_REALM=local

# Base de données IAM (même base que Keycloak)
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5433/keycloak
SPRING_DATASOURCE_USERNAME=keycloak
SPRING_DATASOURCE_PASSWORD=password
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=true

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
SPRING_KAFKA_CONSUMER_GROUP=iam-compte-consumer
SPRING_KAFKA_TOPIC=compte-provisioning

# Profiles
SPRING_PROFILES_ACTIVE=dev
QUARKUS_PROFILE=dev

# =============================================
# Configuration Admin
# =============================================

# Admin initial (créé au premier démarrage)
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin123

# =============================================
# Configuration sécurité
# =============================================

# CORS
KC_HTTP_CORS=true
KC_HTTP_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
KC_HTTP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# HTTPS (désactivé en dev)
KC_HTTPS_ENABLED=false
