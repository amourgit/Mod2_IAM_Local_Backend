# =============================================
# Configuration Keycloak - Tests
# =============================================

# Port HTTP
KC_HTTP_PORT=8081

# Base de données H2 (tests)
KC_DB=h2
KC_DB_URL=jdbc:h2:mem:testdb;DB_CLOSE_DELAY=-1
KC_DB_USERNAME=sa
KC_DB_PASSWORD=
KC_DB_MIGRATION=auto

# Hostname (tests)
KC_HOSTNAME_STRICT=false
KC_HOSTNAME=localhost

# Features activées
KC_FEATURES=preview,account-api

# Logs
KC_LOG_LEVEL=DEBUG
KC_LOG_CONSOLE_OUTPUT=json

# =============================================
# Configuration Module IAM Compte - Tests
# =============================================

# Connexion Keycloak
KEYCLOAK_AUTH_SERVER_URL=http://localhost:8081
KEYCLOAK_REALM=test

# Base de données H2 (tests)
SPRING_DATASOURCE_URL=jdbc:h2:mem:testiam;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=create-drop
SPRING_JPA_SHOW_SQL=true

# Kafka (embedded pour tests)
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9093
SPRING_KAFKA_CONSUMER_GROUP=test-consumer
SPRING_KAFKA_TOPIC=test-compte-provisioning

# Profiles
SPRING_PROFILES_ACTIVE=test
QUARKUS_PROFILE=test

# =============================================
# Configuration tests
# =============================================

# Admin initial
KEYCLOAK_ADMIN=test-admin
KEYCLOAK_ADMIN_PASSWORD=test123

# CORS
KC_HTTP_CORS=true
KC_HTTP_CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
KC_HTTP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081

# HTTPS désactivé pour tests
KC_HTTPS_ENABLED=false
